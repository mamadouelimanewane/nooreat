DATABASE_URL=

# Signe les sessions admin NextAuth (back-office)
NEXTAUTH_SECRET=

# Signe les tokens Bearer des apps mobiles (users/drivers) — requis par src/lib/authToken.ts
AUTH_TOKEN_SECRET=

# Utilisés uniquement par `npx prisma db seed` pour créer le premier compte SuperAdmin
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
# Utilisé uniquement par `npx prisma db seed` pour créer le mot de passe du magasin de démo
STORE_SEED_PASSWORD=
